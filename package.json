{
  "name": "er-diagram-mcp",
  "version": "0.1.0",
  "description": "MCP server for ER Diagram — SQL/DBML schema design, validate, diff, and editor sync (VIP)",
  "type": "module",
  "license": "MIT",
  "author": "meiseayoung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meiseayoung/er-diagram-mcp.git"
  },
  "homepage": "https://github.com/meiseayoung/er-diagram-mcp#readme",
  "bugs": {
    "url": "https://github.com/meiseayoung/er-diagram-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "er-diagram",
    "database",
    "schema",
    "sql",
    "dbml",
    "ddl"
  ],
  "bin": {
